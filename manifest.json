{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.1.0",
  "description": "__MSG_extDescription__",
  "default_locale": "fr",
  "icons": {
    "16": "icons/favicon_16px.png",
    "32": "icons/favicon_32px.png",
    "48": "icons/favicon_48px.png",
    "128": "icons/favicon_128px.png"
  },
  "action": {
    "default_title": "__MSG_actionOpen__",
    "default_icon": "icons/favicon_128px.png"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "permissions": [
    "scripting",
    "activeTab",
    "storage",
    "tabs",
    "clipboardWrite"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [],
  "browser_specific_settings": {
    "gecko": {
      "id": "flashcpap@molipoli-blip"
    }
  }
}
